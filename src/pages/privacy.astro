---
import Layout from '../layouts/Layout.astro';
import { SITE, BIOGRAPHY } from '../data/site';

const lastUpdated = new Date().toLocaleDateString('en-GB', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const linkedInUrl = BIOGRAPHY.social.find((s) => s.name === 'LinkedIn')?.url;
---

<Layout
  title={`Privacy Policy - ${SITE.title}`}
  description="Privacy policy for danielfridljand.de, including AI chat and theme preferences."
  url={`${SITE.url}/privacy`}
>
  <article class="container mx-auto px-4 py-16 max-w-3xl">
    <h1 class="text-4xl font-bold mb-2 text-heading">Privacy Policy</h1>
    <p class="text-muted mb-8">Last updated: {lastUpdated}</p>

    <div class="prose prose-lg dark:prose-invert max-w-none text-body">
      <h2>Who is responsible</h2>
      <p>
        This website ({SITE.url}) is operated by {BIOGRAPHY.name}. For privacy
        questions or requests, contact me via{' '}
        {linkedInUrl ? (
          <a href={linkedInUrl} target="_blank" rel="noopener noreferrer">
            LinkedIn
          </a>
        ) : (
          'LinkedIn'
        )}
        .
      </p>

      <h2>AI chat</h2>
      <p>
        The chat feature sends the messages you type to the Google Gemini API so
        the assistant can respond. Do not enter sensitive personal data you do not
        want processed by a third party. Messages are not stored on this server;
        retention and processing by Google are governed by the{' '}
        <a
          href="https://ai.google.dev/gemini-api/terms"
          target="_blank"
          rel="noopener noreferrer"
        >
          Gemini API terms
        </a>
        .
      </p>

      <h2>Theme preference</h2>
      <p>
        If you change light/dark mode, your choice is saved in your browser under
        the <code>color-theme</code> key in <code>localStorage</code>. This is
        used only to remember your display preference on return visits. It is not
        shared with third parties.
      </p>

      <h2>What we do not collect</h2>
      <p>
        This site does not use analytics cookies, advertising trackers, or
        third-party marketing pixels.
      </p>

      <h2>Your rights</h2>
      <p>
        Depending on where you live, you may have rights to access, correct, or
        delete personal data. Because chat messages are processed by Google and
        not stored on this server, requests regarding chat content may need to be
        directed to Google as well. Contact me via LinkedIn for any requests
        related to this website.
      </p>
    </div>
  </article>
</Layout>
