---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
import { logger } from '../utils/logger';

export const prerender = false;

interface Props {
  error: unknown;
}

const { error } = Astro.props;

if (error) {
  logger.error(
    'Server error:',
    error instanceof Error ? error.message : String(error)
  );
}
---

<Layout
  title={`Server error - ${SITE.title}`}
  description="Something went wrong while loading this page."
  url={`${SITE.url}/500`}
>
  <section class="container mx-auto px-4 py-24 text-center max-w-xl">
    <h1 class="text-5xl font-bold mb-4 text-heading">500</h1>
    <p class="text-xl text-muted mb-8">
      Something went wrong on our end. Please try again later.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="/"
        class="inline-flex items-center justify-center px-6 py-3 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors"
      >
        Back to home
      </a>
      <a
        href="/#posts"
        class="inline-flex items-center justify-center px-6 py-3 border border-surface rounded-lg text-heading hover:bg-surface-alt transition-colors"
      >
        Browse posts
      </a>
    </div>
  </section>
</Layout>
